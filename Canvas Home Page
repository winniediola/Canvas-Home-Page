    <!-- TOAST NOTIFICATION CONTAINER -->
    <div id="toast-container" class="fixed bottom-5 right-5 space-y-2 z-50"></div>

    <script>
        // Core Mock Data Store (stored in Memory + LocalStorage fallback)
        let announcements = [
            { id: 1, date: "June 24, 2026", badge: "Orientation", title: "Digital Security Unit Launch", content: "Our core orientation begins Monday! Please download and review Module 1: Safe Footprints and Online Privacy guidelines before the synchronous session.", isPinned: true },
            { id: 2, date: "June 22, 2026", badge: "Course Outlines", title: "Term 1 Syllabus Syllabus Released", content: "The permanent schedule of modules, discussions, and major interactive assessments has been plotted. Make sure to download the outlines file.", isPinned: false }
        ];

        let courseUnits = [
            { id: 1, name: "Unit 1: Digital Footprint & Reputation", desc: "Understanding the permanent nature of data online and protecting personal privacy trails.", status: "Active Progression", count: "3 lessons" },
            { id: 2, name: "Unit 2: Online Safety & Ethical Netiquette", desc: "Interactive framework exploring cyberbullying containment, media respect, and reporting guidelines.", status: "Upcoming Module", count: "4 lessons" }
        ];

        let assessments = [
            { id: 1, name: "Introductory Quiz: Basic Terms", type: "Online Quiz", due: "2026-06-28", weight: "15%", status: "Open" },
            { id: 2, name: "Interactive Discussion Board Post", type: "Interactive Discussion", due: "2026-07-02", weight: "10%", status: "Pending" }
        ];

        let discussions = [
            { id: 1, author: "Sofia Valenzuela", date: "June 25, 2026", content: "I read an article saying recruiters look at candidate digital footprints. It's crazy that posts we make now can affect us years down the line!" }
        ];

        let courseOutlines = [
            { title: "Week 1: Foundations of Digital Citizenship", desc: "Key terms and digital literacy theories including intellectual property and online netiquette." },
            { title: "Week 2: Securing Your Digital Identity", desc: "Practical workshops regarding credential security, two-factor authentication, and safe network habits." }
        ];

        let calendarEvents = [
            { date: "2026-06-25", title: "Intro Sync Meet", type: "academic" },
            { date: "2026-06-29", title: "Module 1 Review", type: "general" }
        ];

        let classPhotos = [
            { title: "Class Project: Privacy Posters", date: "June 20, 2026", placeholderColor: "bg-emerald-600" },
            { title: "Group Consultation Session", date: "June 22, 2026", placeholderColor: "bg-[#155a3b]" }
        ];

        // On Load initialization
        window.onload = function() {
            loadFromLocalStorage();
            renderAllViews();
            updateEmbedSnippet();
        };

        function showToast(message, type = "success") {
            const container = document.getElementById("toast-container");
            const toast = document.createElement("div");
            toast.className = `p-3.5 rounded-xl shadow-lg text-xs font-bold text-white transition-all duration-300 transform translate-y-2 flex items-center space-x-2 ${
                type === "success" ? "bg-emerald-600" : "bg-red-600"
            }`;
            toast.innerHTML = `<i class="fa-solid ${type === "success" ? "fa-circle-check" : "fa-circle-exclamation"}"></i> <span>${message}</span>`;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove("translate-y-2");
                toast.classList.add("translate-y-0", "opacity-0");
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        function loadFromLocalStorage() {
            if(localStorage.getItem("dc_announcements")) announcements = JSON.parse(localStorage.getItem("dc_announcements"));
            if(localStorage.getItem("dc_course_units")) courseUnits = JSON.parse(localStorage.getItem("dc_course_units"));
            if(localStorage.getItem("dc_assessments")) assessments = JSON.parse(localStorage.getItem("dc_assessments"));
            if(localStorage.getItem("dc_discussions")) discussions = JSON.parse(localStorage.getItem("dc_discussions"));
            if(localStorage.getItem("dc_outlines")) courseOutlines = JSON.parse(localStorage.getItem("dc_outlines"));
            if(localStorage.getItem("dc_photos")) classPhotos = JSON.parse(localStorage.getItem("dc_photos"));
        }

        function saveToLocalStorage() {
            localStorage.setItem("dc_announcements", JSON.stringify(announcements));
            localStorage.setItem("dc_course_units", JSON.stringify(courseUnits));
            localStorage.setItem("dc_assessments", JSON.stringify(assessments));
            localStorage.setItem("dc_discussions", JSON.stringify(discussions));
            localStorage.setItem("dc_outlines", JSON.stringify(courseOutlines));
            localStorage.setItem("dc_photos", JSON.stringify(classPhotos));
        }

        function renderAllViews() {
            renderAnnouncements();
            renderModules();
            renderAssessments();
            renderDiscussions();
            renderOutlines();
            renderSchedule();
            renderPhotos();
        }

        // NAVIGATION
        function switchTab(tabId) {
            document.querySelectorAll(".view-panel").forEach(panel => panel.classList.add("hidden"));
            const targetPanel = document.getElementById(`view-${tabId}`);
            if(targetPanel) targetPanel.classList.remove("hidden");
            
            document.querySelectorAll(".nav-btn").forEach(btn => {
                btn.className = "nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all";
            });
            const activeBtn = document.getElementById(`nav-${tabId}`);
            if(activeBtn) {
                activeBtn.className = "nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold bg-[#e6f4ea] text-[#055a3a] transition-all";
            }
        }

        // 1. ANNOUNCEMENTS MODULE
        function renderAnnouncements() {
            const container = document.getElementById("announcements-container");
            container.innerHTML = "";
            announcements.forEach((ann, index) => {
                const card = document.createElement("div");
                card.className = "bg-white p-5 rounded-2xl border border-slate-100 shadow-sm relative";
                card.innerHTML = `
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center space-x-2">
                            <span class="bg-pink-50 text-pink-600 text-[10px] font-bold px-2.5 py-0.5 rounded-full uppercase">${ann.badge}</span>
                            <span class="text-[10px] text-slate-400 font-semibold">${ann.date}</span>
                        </div>
                        <button onclick="deleteAnnouncement(${index})" class="text-slate-300 hover:text-red-500 transition-all">
                            <i class="fa-solid fa-trash-can text-xs"></i>
                        </button>
                    </div>
                    <h3 class="text-sm font-bold text-slate-800">${ann.title}</h3>
                    <p class="text-xs text-slate-500 mt-2 leading-relaxed">${ann.content}</p>
                `;
                container.appendChild(card);
            });
        }

        function openAddAnnouncementModal() {
            document.getElementById("add-announcement-modal").classList.remove("hidden");
        }

        function closeAddAnnouncementModal() {
            document.getElementById("add-announcement-modal").classList.add("hidden");
        }

        function handleAddAnnouncement(e) {
            e.preventDefault();
            const badge = document.getElementById("new-ann-badge").value;
            const title = document.getElementById("new-ann-title").value;
            const content = document.getElementById("new-ann-content").value;
            announcements.unshift({ id: Date.now(), date: "June 25, 2026", badge, title, content });
            saveToLocalStorage();
            renderAnnouncements();
            closeAddAnnouncementModal();
            showToast("New Course bulletin successfully broadcasted.");
            e.target.reset();
        }

        function deleteAnnouncement(index) {
            announcements.splice(index, 1);
            saveToLocalStorage();
            renderAnnouncements();
            showToast("Announcement deleted.", "info");
        }

        // 2. MODULES
        function renderModules() {
            const container = document.getElementById("modules-container");
            container.innerHTML = "";
            courseUnits.forEach((unit, index) => {
                const card = document.createElement("div");
                card.className = "bg-white p-6 rounded-2xl border border-slate-100 shadow-sm flex flex-col justify-between space-y-4 hover:border-emerald-200 transition-all";
                card.innerHTML = `
                    <div>
                        <div class="flex justify-between items-center">
                            <span class="text-[10px] text-emerald-600 bg-emerald-50 font-bold px-2.5 py-0.5 rounded-full uppercase">${unit.status}</span>
                            <span class="text-[10px] text-slate-400">${unit.count}</span>
                        </div>
                        <h4 class="text-sm font-extrabold text-slate-800 mt-3">${unit.name}</h4>
                        <p class="text-xs text-slate-500 mt-2 leading-relaxed">${unit.desc}</p>
                    </div>
                    <div class="flex justify-between items-center border-t border-slate-50 pt-3">
                        <button onclick="downloadUnit(${index})" class="text-xs font-bold text-[#055a3a] hover:underline flex items-center space-x-1">
                            <i class="fa-solid fa-cloud-arrow-down text-[10px]"></i>
                            <span>Download Guides</span>
                        </button>
                        <button onclick="deleteModule(${index})" class="text-slate-300 hover:text-red-500">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        function addCourseUnit() {
            const name = prompt("Enter Module Title:");
            if(!name) return;
            const desc = prompt("Enter Brief Outline Description:");
            courseUnits.push({ id: Date.now(), name, desc: desc || "General materials", status: "Active", count: "3 lessons" });
            saveToLocalStorage();
            renderModules();
            showToast("Module unit successfully published.");
        }

        function downloadUnit(idx) {
            showToast(`Generating course assets for: ${courseUnits[idx].name}`);
        }

        function deleteModule(index) {
            courseUnits.splice(index, 1);
            saveToLocalStorage();
            renderModules();
            showToast("Module deleted.", "info");
        }

        // 3. ASSESSMENTS
        function renderAssessments() {
            const tbody = document.getElementById("assessments-table-rows");
            tbody.innerHTML = "";
            assessments.forEach((ass, index) => {
                const tr = document.createElement("tr");
                tr.className = "hover:bg-slate-50 transition-all";
                tr.innerHTML = `
                    <td class="p-4 font-semibold text-slate-800">${ass.name}</td>
                    <td class="p-4 text-slate-500">${ass.type}</td>
                    <td class="p-4 text-slate-400 font-mono">${ass.due}</td>
                    <td class="p-4 font-bold text-slate-700">${ass.weight}</td>
                    <td class="p-4">
                        <span class="text-[10px] font-bold uppercase text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">${ass.status}</span>
                    </td>
                    <td class="p-4 text-right">
                        <button onclick="deleteAssessment(${index})" class="text-slate-300 hover:text-red-500 transition-all">
                            <i class="fa-solid fa-trash-can text-xs"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function openAddAssessmentModal() {
            document.getElementById("add-assessment-modal").classList.remove("hidden");
        }

        function closeAddAssessmentModal() {
            document.getElementById("add-assessment-modal").classList.add("hidden");
        }

        function handleAddAssessment(e) {
            e.preventDefault();
            const name = document.getElementById("new-ass-name").value;
            const type = document.getElementById("new-ass-type").value;
            const due = document.getElementById("new-ass-due").value;
            const weight = document.getElementById("new-ass-weight").value + "%";

            assessments.unshift({ id: Date.now(), name, type, due, weight, status: "Open" });
            saveToLocalStorage();
            renderAssessments();
            closeAddAssessmentModal();
            showToast("Graded Assessment added to Canvas track.");
            e.target.reset();
        }

        function deleteAssessment(index) {
            assessments.splice(index, 1);
            saveToLocalStorage();
            renderAssessments();
            showToast("Assessment target removed.", "info");
        }

        // 4. DISCUSSIONS
        function renderDiscussions() {
            const container = document.getElementById("discussions-container");
            container.innerHTML = "";
            discussions.forEach((post, index) => {
                const card = document.createElement("div");
                card.className = "bg-white p-5 rounded-2xl border border-slate-100 shadow-sm space-y-3 relative";
                card.innerHTML = `
                    <div class="flex items-center justify-between">
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center text-[#055a3a] font-bold text-xs uppercase">
                                ${post.author[0]}
                            </div>
                            <div>
                                <h5 class="text-xs font-bold text-slate-800">${post.author}</h5>
                                <span class="text-[9px] text-slate-400 block">${post.date}</span>
                            </div>
                        </div>
                        <button onclick="deletePost(${index})" class="text-slate-300 hover:text-red-500">
                            <i class="fa-solid fa-trash-can text-xs"></i>
                        </button>
                    </div>
                    <p class="text-xs text-slate-500 leading-relaxed bg-slate-50/50 p-3 rounded-xl border border-slate-50">${post.content}</p>
                `;
                container.appendChild(card);
            });
        }

        function postDiscussion(e) {
            e.preventDefault();
            const author = document.getElementById("forum-author").value;
            const content = document.getElementById("forum-content").value;
            discussions.unshift({ id: Date.now(), author, date: "June 25, 2026", content });
            saveToLocalStorage();
            renderDiscussions();
            showToast("Discussion post active!");
            e.target.reset();
        }

        function deletePost(index) {
            discussions.splice(index, 1);
            saveToLocalStorage();
            renderDiscussions();
            showToast("Forum post deleted.");
        }

        // 5. OUTLINES
        function renderOutlines() {
            const container = document.getElementById("outlines-accordion");
            container.innerHTML = "";
            courseOutlines.forEach((out, index) => {
                const card = document.createElement("div");
                card.className = "bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden";
                card.innerHTML = `
                    <div class="p-4 bg-slate-50 border-b border-slate-100 flex justify-between items-center cursor-pointer" onclick="this.nextElementSibling.classList.toggle('hidden')">
                        <h4 class="text-xs font-bold text-slate-800">${out.title}</h4>
                        <i class="fa-solid fa-chevron-down text-slate-400 text-[10px]"></i>
                    </div>
                    <div class="p-4 space-y-2 text-xs text-slate-500">
                        <p>${out.desc}</p>
                        <div class="pt-2 border-t border-slate-50 flex space-x-4 text-[11px] text-[#055a3a] font-bold">
                            <button onclick="showToast('Syllabus file prepared for download')">📄 Download Handout</button>
                            <button onclick="showToast('Active worksheet guidelines loaded')">🔗 Lesson Activities</button>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // 6. SCHEDULE
        function renderSchedule() {
            const grid = document.getElementById("scheduler-days-grid");
            grid.innerHTML = "";
            for (let d = 1; d <= 30; d++) {
                const day = document.createElement("div");
                day.className = `p-2 min-h-12 border border-slate-50 text-right text-xs rounded-lg ${
                    d === 25 ? 'bg-emerald-50 text-[#055a3a] font-black border-emerald-300' : 'bg-white text-slate-500'
                }`;
                day.innerHTML = `<span>${d}</span>`;
                grid.appendChild(day);
            }

            const list = document.getElementById("scheduler-checklist");
            list.innerHTML = `
                <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 flex justify-between text-xs">
                    <div>
                        <span class="text-[9px] text-emerald-600 font-bold block uppercase">Synchronous Meet</span>
                        <strong>Intro to Digital Safety</strong>
                    </div>
                    <span class="text-slate-400">June 25</span>
                </div>
                <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 flex justify-between text-xs">
                    <div>
                        <span class="text-[9px] text-blue-600 font-bold block uppercase">Asynchronous Work</span>
                        <strong>Module 1 Worksheet Handout</strong>
                    </div>
                    <span class="text-slate-400">June 29</span>
                </div>
            `;
        }

        // 8. CLASS PHOTOS GALLERY
        function renderPhotos() {
            const grid = document.getElementById("photos-grid");
            grid.innerHTML = "";
            classPhotos.forEach((photo, index) => {
                const card = document.createElement("div");
                card.className = "bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden group";
                card.innerHTML = `
                    <div class="h-32 ${photo.placeholderColor} flex items-center justify-center text-white relative">
                        <i class="fa-solid fa-images text-2xl opacity-40 group-hover:scale-110 transition-all duration-300"></i>
                    </div>
                    <div class="p-4 space-y-1">
                        <span class="text-[9px] text-slate-400 font-bold uppercase">${photo.date}</span>
                        <h5 class="text-xs font-bold text-slate-800 leading-tight">${photo.title}</h5>
                        <div class="flex justify-end pt-2 border-t border-slate-50 mt-2">
                            <button onclick="deletePhoto(${index})" class="text-slate-300 hover:text-red-500 text-xs">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        function triggerPhotoUpload() {
            const title = prompt("Enter Photo Caption Title:");
            if(!title) return;
            const colors = ["bg-emerald-600", "bg-amber-500", "bg-blue-600", "bg-indigo-600", "bg-pink-600"];
            const placeholderColor = colors[Math.floor(Math.random() * colors.length)];
            classPhotos.unshift({ title, date: "June 25, 2026", placeholderColor });
            saveToLocalStorage();
            renderPhotos();
            showToast("Snapshot pinned to portal gallery.");
        }

        function deletePhoto(index) {
            classPhotos.splice(index, 1);
            saveToLocalStorage();
            renderPhotos();
            showToast("Photo entry removed.");
        }

        // SETTINGS
        function toggleSettingsModal() {
            const modal = document.getElementById("settings-modal");
            modal.classList.toggle("hidden");
            if(!modal.classList.contains("hidden")) {
                document.getElementById("settings-gmeet-link").value = localStorage.getItem("dc_meet_link") || "https://meet.google.com";
            }
        }

        function saveSettings() {
            const meet = document.getElementById("settings-gmeet-link").value;
            localStorage.setItem("dc_meet_link", meet);
            toggleSettingsModal();
            showToast("Course Lobby link successfully updated.");
        }

        // CANVAS EMBED LOGIC
        function openEmbedModal() {
            updateEmbedSnippet();
            document.getElementById("embed-modal").classList.remove("hidden");
        }

        function closeEmbedModal() {
            document.getElementById("embed-modal").classList.add("hidden");
        }

        function updateEmbedSnippet() {
            const box = document.getElementById("embed-code-box");
            const currentURL = window.location.href;
            box.value = `<iframe src="${currentURL}" width="100%" height="800px" style="border: 1px solid #e2e8f0; border-radius: 20px; box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);" allowfullscreen></iframe>`;
        }

        function copyEmbedCode() {
            const box = document.getElementById("embed-code-box");
            box.select();
            document.execCommand('copy');
            showToast("Integration embed code copied!");
        }
    </script>
</body>
</html>
