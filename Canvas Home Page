<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Citizenship Portal - Animo Homeroom</title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for standard UI icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        .green-gradient {
            background: linear-gradient(135deg, #1e5c3f 0%, #0c8254 100%);
        }
        .spark-shine {
            text-shadow: 0 0 15px rgba(251, 191, 36, 0.6);
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

    <!-- Top Navigation Header -->
    <header class="bg-white border-b border-slate-100 px-6 py-4 flex flex-wrap items-center justify-between sticky top-0 z-30 shadow-sm">
        <div class="flex items-center space-x-3 mb-2 md:mb-0">
            <!-- Logo Icon -->
            <div class="w-10 h-10 rounded-xl bg-[#055a3a] flex items-center justify-center text-white shadow-md">
                <i class="fa-solid fa-laptop-code text-lg"></i>
            </div>
            <div>
                <div class="flex items-center space-x-2">
                    <span class="text-xs font-bold tracking-wider text-[#055a3a] uppercase">Animo Homeroom</span>
                </div>
                <h1 class="text-lg md:text-xl font-bold text-slate-900 tracking-tight">Digital Citizenship Course Hub</h1>
            </div>
        </div>

        <div class="flex items-center space-x-3">
            <button onclick="openEmbedModal()" class="flex items-center space-x-2 px-3.5 py-1.5 text-xs font-semibold text-[#055a3a] border border-[#055a3a]/30 hover:bg-emerald-50 rounded-lg transition-all">
                <i class="fa-solid fa-code"></i>
                <span>Canvas Embed Code</span>
            </button>
            <button onclick="toggleSettingsModal()" class="flex items-center space-x-2 px-3.5 py-1.5 text-xs font-semibold text-[#055a3a] border border-emerald-100 hover:bg-emerald-50 rounded-lg transition-all">
                <i class="fa-solid fa-gears"></i>
                <span>Portal Settings</span>
            </button>
            <div class="h-8 w-[1px] bg-slate-200"></div>
            <div class="flex items-center space-x-2">
                <div class="w-8 h-8 rounded-full bg-emerald-100 text-[#055a3a] flex items-center justify-center font-bold text-sm">
                    DC
                </div>
                <div class="hidden sm:block text-left leading-none">
                    <p class="text-xs font-semibold text-slate-800">Ms. Winnie Y. Diola</p>
                    <span class="text-[10px] text-slate-400">AY 2026 - 2027</span>
                </div>
            </div>
        </div>
    </header>

    <div class="flex flex-1 flex-col lg:flex-row relative">
        <!-- Sidebar Navigation -->
        <aside class="w-full lg:w-64 bg-white lg:border-r border-slate-100 p-5 flex flex-col justify-between shrink-0">
            <div class="space-y-6">
                <div>
                    <span class="text-[10px] font-bold text-slate-400 tracking-widest uppercase text-xs">Course Navigation</span>
                    <nav class="mt-3 space-y-1.5">
                        <button onclick="switchTab('dashboard')" id="nav-dashboard" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold bg-[#e6f4ea] text-[#055a3a] transition-all">
                            <i class="fa-solid fa-house w-4 text-center"></i>
                            <span>Course Dashboard</span>
                        </button>
                        <button onclick="switchTab('announcements')" id="nav-announcements" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-bullhorn w-4 text-center"></i>
                            <span>1. Announcements</span>
                        </button>
                        <button onclick="switchTab('modules')" id="nav-modules" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-folder-open w-4 text-center"></i>
                            <span>2. Modules</span>
                        </button>
                        <button onclick="switchTab('assessments')" id="nav-assessments" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-pen-to-square w-4 text-center"></i>
                            <span>3. Assessments</span>
                        </button>
                        <button onclick="switchTab('discussions')" id="nav-discussions" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-comments w-4 text-center"></i>
                            <span>4. Discussions</span>
                        </button>
                        <button onclick="switchTab('outlines')" id="nav-outlines" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-book-open w-4 text-center"></i>
                            <span>5. Course Outlines</span>
                        </button>
                        <button onclick="switchTab('schedule')" id="nav-schedule" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-calendar-alt w-4 text-center"></i>
                            <span>6. Online Schedule</span>
                        </button>
                        <button onclick="switchTab('gmeet')" id="nav-gmeet" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-video w-4 text-center text-emerald-600"></i>
                            <span>7. Google Meet Room</span>
                        </button>
                        <button onclick="switchTab('photos')" id="nav-photos" class="nav-btn w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-xs font-semibold text-slate-600 hover:bg-slate-50 transition-all">
                            <i class="fa-solid fa-camera w-4 text-center"></i>
                            <span>8. Activity Photos</span>
                        </button>
                    </nav>
                </div>

                <!-- Class Details -->
                <div class="border-t border-slate-100 pt-5">
                    <span class="text-[10px] font-bold text-slate-400 tracking-widest uppercase">Course Metadata</span>
                    <div class="mt-3 space-y-2.5 text-xs text-slate-600">
                        <div class="flex justify-between">
                            <span class="text-slate-400">Instructor:</span>
                            <span class="font-bold text-slate-800">Ms. Winnie Y. Diola</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-slate-400">Grade Level:</span>
                            <span class="font-bold text-slate-800">Grades 1-6 & BRafeNHS</span>
                        </div>
                        <div class="mt-4 pt-3 border-t border-slate-50">
                            <span class="text-[10px] font-bold text-[#055a3a] uppercase block tracking-wider">Motto & Vision</span>
                            <span class="italic text-[11px] text-emerald-800 mt-1 block">"Be a SPARK, take the LEAD"</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer Meta -->
            <div class="text-[10px] text-slate-400 mt-8 pt-4 border-t border-slate-100">
                <p>&copy; 2027 Animo Homeroom</p>
                <p class="mt-1">Digital Citizenship Hub</p>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-y-auto">
            
            <!-- VIEW: HUB DASHBOARD -->
            <div id="view-dashboard" class="view-panel space-y-8">
                <!-- Custom Green Hero Banner from Image asset matching characters style -->
                <div class="green-gradient rounded-3xl p-6 sm:p-8 text-white relative overflow-hidden shadow-lg shadow-emerald-950/20">
                    <!-- Starburst / cute vectors -->
                    <div class="absolute right-6 top-6 text-yellow-300 spark-shine text-3xl animate-bounce">
                        <i class="fa-solid fa-star"></i>
                    </div>
                    <div class="absolute left-1/3 bottom-2 text-emerald-400/20 text-7xl font-black">
                        AY 2026-2027
                    </div>
                    
                    <div class="relative z-10 max-w-3xl flex flex-col md:flex-row justify-between items-center gap-6">
                        <div class="space-y-3 text-center md:text-left">
                            <span class="bg-[#155a3b] border border-emerald-400/40 text-[10px] font-bold tracking-widest uppercase px-3 py-1 rounded-full text-emerald-200 inline-block">
                                Welcome to AY 2026-2027
                            </span>
                            <h2 class="text-3xl sm:text-4.5xl font-extrabold tracking-tight leading-tight">
                                Be a <span class="text-amber-300 spark-shine font-black">SPARK</span>, Take the <span class="underline decoration-yellow-400 decoration-wavy">LEAD</span>.
                            </h2>
                            <p class="text-xs sm:text-sm text-emerald-100/90 font-normal leading-relaxed max-w-xl">
                                Welcome to your central command center for **Digital Citizenship**. Use the interactive buttons below to track assignments, schedules, discussions, and download weekly lesson guides.
                            </p>
                        </div>
                        
                        <!-- Illustration Placeholder / Cute Mascot Box -->
                        <div class="w-32 h-32 bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-4 flex flex-col items-center justify-center text-center shrink-0">
                            <div class="text-3xl">🧑‍💻👩‍💻</div>
                            <span class="text-[10px] uppercase font-bold text-emerald-200 mt-2 tracking-wider">Be Safe Online</span>
                        </div>
                    </div>
                </div>

                <!-- 8 CIRCULAR NAV BUTTONS SECTION -->
                <div class="space-y-4">
                    <div class="flex items-center space-x-2 pb-1 border-b border-slate-100">
                        <i class="fa-solid fa-circle-nodes text-[#055a3a] text-sm"></i>
                        <h3 class="text-xs font-bold text-slate-500 tracking-wider uppercase">Class Navigation Hub</h3>
                    </div>

                    <!-- Grid layout of the 8 circular buttons from image 2 -->
                    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-4 pt-2">
                        <!-- 1. Announcements -->
                        <button onclick="switchTab('announcements')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-bullhorn text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Announcements</span>
                        </button>

                        <!-- 2. Modules -->
                        <button onclick="switchTab('modules')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-box text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Modules</span>
                        </button>

                        <!-- 3. Assessments -->
                        <button onclick="switchTab('assessments')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-pen-ruler text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Assessments</span>
                        </button>

                        <!-- 4. Discussions -->
                        <button onclick="switchTab('discussions')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-comments text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Discussions</span>
                        </button>

                        <!-- 5. Course Outlines -->
                        <button onclick="switchTab('outlines')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-book-bookmark text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Course Outlines</span>
                        </button>

                        <!-- 6. Online Class Schedule -->
                        <button onclick="switchTab('schedule')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-clock-rotate-left text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Class Schedule</span>
                        </button>

                        <!-- 7. Google Meet -->
                        <button onclick="switchTab('gmeet')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-amber-500 hover:bg-amber-600 text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-amber-100">
                                <i class="fa-solid fa-video text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Google Meet</span>
                        </button>

                        <!-- 8. Class Activity Photos -->
                        <button onclick="switchTab('photos')" class="group flex flex-col items-center text-center space-y-2.5">
                            <div class="w-20 h-20 rounded-full bg-[#1a5a3a] hover:bg-[#206f47] text-white flex items-center justify-center shadow-md transition-all duration-300 transform group-hover:scale-110 ring-4 ring-emerald-100">
                                <i class="fa-solid fa-camera-retro text-2xl"></i>
                            </div>
                            <span class="text-[10.5px] font-bold text-slate-700 tracking-tight leading-tight group-hover:text-[#055a3a] uppercase">Activity Photos</span>
                        </button>
                    </div>
                </div>

                <!-- Learning Progress Highlights / Info Widgets -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pt-4">
                    <!-- Progress Card -->
                    <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm space-y-4">
                        <div class="flex justify-between items-center">
                            <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Course Progression</h4>
                            <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2 py-0.5 rounded-full">Term 1</span>
                        </div>
                        <div class="space-y-2">
                            <div class="flex justify-between text-xs">
                                <span class="font-bold text-slate-700">Digital Footprint Awareness</span>
                                <span class="text-slate-400">75% Completed</span>
                            </div>
                            <div class="w-full bg-slate-100 h-2 rounded-full overflow-hidden">
                                <div class="bg-emerald-600 h-full rounded-full" style="width: 75%"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Teacher Contact / Advisory Info -->
                    <div class="bg-white rounded-2xl p-6 border border-slate-100 shadow-sm flex flex-col justify-between">
                        <div class="flex justify-between items-center">
                            <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Teacher Consultation</h4>
                            <span class="text-[10px] text-amber-600 font-bold bg-amber-50 px-2 py-0.5 rounded-full">Available</span>
                        </div>
                        <p class="text-xs text-slate-500 mt-2">Have concerns about digital privacy or your online safety portfolio? Send a direct email to <strong>Ms. Winnie Y. Diola</strong> or schedule a consultation hour.</p>
                        <div class="mt-4 flex space-x-2">
                            <a href="mailto:w.diola@animo.edu" class="px-4 py-2 bg-[#055a3a] hover:bg-[#044c31] text-white text-xs font-bold rounded-xl flex items-center space-x-2 transition-all">
                                <i class="fa-solid fa-envelope"></i>
                                <span>Email Instructor</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- VIEW: ANNOUNCEMENTS -->
            <div id="view-announcements" class="view-panel hidden space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-4 gap-4">
                    <div>
                        <span class="text-xs font-bold text-pink-600 bg-pink-50 px-2.5 py-1 rounded-full">Course Announcements</span>
                        <h2 class="text-xl font-bold mt-2 text-slate-900">Latest Course Bulletins</h2>
                        <p class="text-xs text-slate-500 mt-1">Class wide reminders, upcoming assignment targets, and resources.</p>
                    </div>
                    <button onclick="openAddAnnouncementModal()" class="px-4 py-2 bg-[#055a3a] hover:bg-[#044c31] text-white text-xs font-semibold rounded-xl flex items-center space-x-2 transition-all">
                        <i class="fa-solid fa-plus text-[10px]"></i>
                        <span>Add Announcement</span>
                    </button>
                </div>

                <div class="space-y-4" id="announcements-container">
                    <!-- Loaded dynamically -->
                </div>
            </div>

            <!-- VIEW: MODULES -->
            <div id="view-modules" class="view-panel hidden space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-4 gap-4">
                    <div>
                        <span class="text-xs font-bold text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full">Syllabus Path</span>
                        <h2 class="text-xl font-bold mt-2 text-slate-900">Learning Modules</h2>
                        <p class="text-xs text-slate-500 mt-1">Access detailed unit material, presentation links, and self-checks.</p>
                    </div>
                    <button onclick="addCourseUnit()" class="px-4 py-2 bg-[#055a3a] hover:bg-[#044c31] text-white text-xs font-semibold rounded-xl flex items-center space-x-2 transition-all">
                        <i class="fa-solid fa-plus text-[10px]"></i>
                        <span>Add Module Unit</span>
                    </button>
                </div>

                <!-- Interactive Course Units Progression Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6" id="modules-container">
                    <!-- Dynamic units load -->
                </div>
            </div>

            <!-- VIEW: ASSESSMENTS -->
            <div id="view-assessments" class="view-panel hidden space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-4 gap-4">
                    <div>
                        <span class="text-xs font-bold text-amber-600 bg-amber-50 px-2.5 py-1 rounded-full">Task Log</span>
                        <h2 class="text-xl font-bold mt-2 text-slate-900">Assessments Tracker</h2>
                        <p class="text-xs text-slate-500 mt-1">Review upcoming deadlines, quiz submissions, and active grades.</p>
                    </div>
                    <button onclick="openAddAssessmentModal()" class="px-4 py-2 bg-[#055a3a] hover:bg-[#044c31] text-white text-xs font-semibold rounded-xl flex items-center space-x-2 transition-all">
                        <i class="fa-solid fa-plus text-[10px]"></i>
                        <span>New Graded Task</span>
                    </button>
                </div>

                <!-- Assessments Registry list -->
                <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 border-b border-slate-100 text-slate-500 font-bold uppercase tracking-wider">
                                <th class="p-4">Assessment Name</th>
                                <th class="p-4">Type</th>
                                <th class="p-4">Due Date</th>
                                <th class="p-4">Weight</th>
                                <th class="p-4">Status</th>
                                <th class="p-4 text-right">Delete</th>
                            </tr>
                        </thead>
                        <tbody id="assessments-table-rows" class="divide-y divide-slate-100">
                            <!-- Loaded via JS -->
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- VIEW: DISCUSSIONS -->
            <div id="view-discussions" class="view-panel hidden space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-4 gap-4">
                    <div>
                        <span class="text-xs font-bold text-blue-600 bg-blue-50 px-2.5 py-1 rounded-full">Netiquette Board</span>
                        <h2 class="text-xl font-bold mt-2 text-slate-900">Interactive Class Discussions</h2>
                        <p class="text-xs text-slate-500 mt-1">Share thoughts, ask questions, and engage on digital citizenship topics.</p>
                    </div>
                </div>

                <!-- Simple Mock Forum Creator -->
                <div class="bg-white rounded-2xl border border-slate-100 p-6 shadow-sm space-y-4">
                    <h3 class="text-sm font-bold text-slate-800">Add to the Conversation</h3>
                    <form onsubmit="postDiscussion(event)" class="space-y-3">
                        <input type="text" id="forum-author" required placeholder="Your Name" class="w-full border border-slate-200 rounded-xl p-2.5 text-xs focus:ring-1 focus:ring-emerald-600">
                        <textarea id="forum-content" required rows="3" placeholder="Share an article, thought, or digital footprint insight..." class="w-full border border-slate-200 rounded-xl p-2.5 text-xs focus:ring-1 focus:ring-emerald-600"></textarea>
                        <button type="submit" class="px-5 py-2 bg-[#055a3a] hover:bg-[#044c31] text-white text-xs font-semibold rounded-xl transition-all">
                            Post to Forum
                        </button>
                    </form>
                </div>

                <div class="space-y-4" id="discussions-container">
                    <!-- Dynamic Forum Feed -->
                </div>
            </div>

            <!-- VIEW: COURSE OUTLINES -->
            <div id="view-outlines" class="view-panel hidden space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-4 gap-4">
                    <div>
                        <span class="text-xs font-bold text-indigo-600 bg-indigo-50 px-2.5 py-1 rounded-full">Syllabus Outline</span>
                        <h2 class="text-xl font-bold mt-2 text-slate-900">Course Syllabus & Schedule Roadmap</h2>
                        <p class="text-xs text-slate-500 mt-1">Official learning objectives and lesson blueprints.</p>
                    </div>
                </div>

                <!-- Structured Accordion Outline Content -->
                <div class="space-y-4 max-w-4xl" id="outlines-accordion">
                    <!-- Loaded dynamically via JS -->
                </div>
            </div>

            <!-- VIEW: ONLINE CLASS SCHEDULE -->
            <div id="view-schedule" class="view-panel hidden space-y-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center border-b border-slate-100 pb-4 gap-4">
